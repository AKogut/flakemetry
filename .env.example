# Instance-wide scoring policy override. Highest precedence: overrides both the
# per-project policy set in the dashboard and the built-in defaults. Leave unset
# to let the dashboard (or defaults) decide. Applies to every project.
FLAKEMETRY_FLAKY_THRESHOLD=
FLAKEMETRY_FLAKY_MIN_SAMPLES=
FLAKEMETRY_QUARANTINE_ENABLED=
FLAKEMETRY_QUARANTINE_COOLDOWN_RUNS=
FLAKEMETRY_AI_RCA=
