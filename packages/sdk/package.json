{
  "name": "@flakemetry/sdk",
  "version": "0.0.0",
  "description": "OpenTelemetry test instrumentation and ingest client",
  "license": "MIT",
  "author": "Andrii Kohut",
  "homepage": "https://github.com/AKogut/flakemetry#readme",
  "bugs": "https://github.com/AKogut/flakemetry/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AKogut/flakemetry.git",
    "directory": "packages/sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "clean": "rm -rf dist .turbo",
    "test": "vitest run"
  },
  "devDependencies": {
    "@flakemetry/eslint-config": "workspace:*",
    "@flakemetry/tsconfig": "workspace:*",
    "@flakemetry/tsup-config": "workspace:*",
    "@types/node": "^22.10.5",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@flakemetry/contracts": "workspace:*",
    "@flakemetry/core": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/core": "^2.0.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.0.0",
    "@opentelemetry/sdk-trace-base": "^2.0.0",
    "@opentelemetry/semantic-conventions": "^1.28.0"
  }
}
