{
  "name": "@flakemetry/contracts",
  "version": "0.0.0",
  "private": true,
  "description": "Shared zod schemas and inferred types across ingestion, api, worker and web",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@flakemetry/eslint-config": "workspace:*",
    "@flakemetry/tsconfig": "workspace:*",
    "@flakemetry/tsup-config": "workspace:*",
    "vitest": "^3.2.4"
  }
}
