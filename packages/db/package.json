{
  "name": "@flakemetry/db",
  "version": "0.0.0",
  "private": true,
  "description": "Prisma schema, migrations and generated client",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "prisma"
  ],
  "scripts": {
    "build": "prisma generate && tsup",
    "typecheck": "prisma generate && tsc -p tsconfig.json",
    "lint": "eslint .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "tsx prisma/seed.ts",
    "clean": "rm -rf dist .turbo",
    "test": "prisma generate && vitest run"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1"
  },
  "devDependencies": {
    "@flakemetry/eslint-config": "workspace:*",
    "@flakemetry/tsconfig": "workspace:*",
    "@flakemetry/tsup-config": "workspace:*",
    "@types/node": "^22.10.5",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "vitest": "^3.2.4"
  }
}
