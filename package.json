{
  "name": "flakemetry",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "dev": "turbo run dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @flakemetry/db db:generate",
    "db:migrate": "pnpm --filter @flakemetry/db db:migrate",
    "db:reset": "pnpm --filter @flakemetry/db db:reset",
    "db:seed": "pnpm --filter @flakemetry/db db:seed"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
